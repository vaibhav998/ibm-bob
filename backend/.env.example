# ============================================================
# Northstar Sales Intelligence — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Database -----------------------------------------------------------
# SQLite (default, zero config):
DATABASE_URL=sqlite:///./northstar.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://sales_user:sales_password@localhost:5432/sales_coaching_db

# --- API ----------------------------------------------------------------
API_V1_PREFIX=/api/v1
PROJECT_NAME=IBM Sales Coaching API
VERSION=1.0.0

# --- CORS ---------------------------------------------------------------
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:8000","null"]

# --- Server -------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
RELOAD=True

# --- Reports ------------------------------------------------------------
REPORTS_DIR=./reports
REPORTS_EXPIRY_DAYS=7

# ============================================================
# Salesforce CRM Integration (optional)
# Leave all SF_* vars blank to run in mock-data mode.
# See SALESFORCE_SETUP.md for step-by-step instructions.
# ============================================================

# Your Salesforce login e-mail (same as your Salesforce username)
SF_USERNAME=your.name@yourcompany.com

# Your Salesforce password
SF_PASSWORD=YourSalesforcePassword

# Security token — obtained from Salesforce:
#   Setup → (your name top-right) → Settings → My Personal Information → Reset My Security Token
# Leave blank only if your server IP is in your org's Trusted IP Ranges.
SF_SECURITY_TOKEN=AbCdEf1234567890XyZ

# Connected App credentials — see SALESFORCE_SETUP.md Step 3
SF_CONSUMER_KEY=3MVG9...your_consumer_key_here
SF_CONSUMER_SECRET=ABCDEF1234567890...your_consumer_secret_here

# 'login' for production orgs, 'test' for sandbox/developer orgs
SF_DOMAIN=login
